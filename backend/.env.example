# ========== Application ==========
APP_NAME=AIS
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# ========== API Server ==========
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ========== CORS ==========
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ========== Base de données PostgreSQL ==========
# Remplacer CHANGE_ME par le vrai mot de passe après clone
DATABASE_URL=postgresql+asyncpg://ais_user:CHANGE_ME@localhost:5432/ais_db
DATABASE_URL_SYNC=postgresql://ais_user:CHANGE_ME@localhost:5432/ais_db

# ========== ASR ==========
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=auto

# ========== Logging ==========
LOG_LEVEL=INFO
LOG_FORMAT=console
LOG_FILE=logs/ais.log

# ========== Sessions ==========
SESSION_MAX_DURATION_HOURS=4
TRANSCRIPTION_BUFFER_SECONDS=3